generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  MANAGER
  DOCTOR
  PATIENT
}

enum Sex {
  MALE
  FEMALE
  OTHER
  UNDISCLOSED
}

enum AppointmentStatus {
  BOOKED
  COMPLETED
  CANCELLED
}

// ─── Reference data ────────────────────────────────────────────────────────────

model NutritionPlan {
  id        String   @id @default(cuid())
  orgId     String
  name      String
  createdBy String
  createdAt DateTime @default(now())

  patients Patient[]

  @@unique([orgId, name])
  @@index([orgId])
}

model MetricType {
  id         String   @id @default(cuid())
  orgId      String
  name       String
  unit       String?
  doctorOnly Boolean  @default(false)
  createdBy  String
  createdAt  DateTime @default(now())

  appointmentMetrics AppointmentMetric[]
  measurements       MeasurementEntry[]

  @@unique([orgId, name])
  @@index([orgId])
}

// ─── Users & patients ──────────────────────────────────────────────────────────

model User {
  id          String   @id @default(cuid())
  clerkId     String   @unique
  orgId       String
  role        Role
  email       String   @unique
  displayName String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  patientProfile   Patient?        @relation("PatientUser")
  assignedPatients Patient[]       @relation("AssignedDoctor")
  appointments     Appointment[]   @relation("AppointmentDoctor")
  notes            Note[]
  measurements     MeasurementEntry[]
  weeklySchedule   WeeklySchedule[]
  calendarBlocks   CalendarBlock[]
  audits           AuditEvent[]
  conversations    Conversation[]
  assetComments    AssetComment[]

  @@index([orgId, role])
}

model Patient {
  id               String    @id @default(cuid())
  orgId            String
  userId           String?   @unique
  assignedDoctorId String?
  firstName        String
  lastName         String
  dob              DateTime?
  sex              Sex       @default(UNDISCLOSED)
  phone            String?
  nutritionPlanId  String?
  clinicalSummary  String?
  color            String?
  isActive         Boolean   @default(false)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  user           User?          @relation("PatientUser", fields: [userId], references: [id], onDelete: SetNull)
  assignedDoctor User?          @relation("AssignedDoctor", fields: [assignedDoctorId], references: [id], onDelete: SetNull)
  nutritionPlan  NutritionPlan? @relation(fields: [nutritionPlanId], references: [id], onDelete: SetNull)

  appointmentParticipants AppointmentParticipant[]
  measurementEntries      MeasurementEntry[]
  uploadedAssets          UploadedAsset[]
  notes                   Note[]
  appointmentMetrics      AppointmentMetric[]
  conversations           Conversation[]

  @@index([orgId])
  @@index([assignedDoctorId])
}

// ─── Appointments ──────────────────────────────────────────────────────────────

model Appointment {
  id          String            @id @default(cuid())
  orgId       String
  doctorId    String
  status      AppointmentStatus @default(BOOKED)
  scheduledAt DateTime
  completedAt DateTime?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  doctor       User                     @relation("AppointmentDoctor", fields: [doctorId], references: [id], onDelete: Restrict)
  participants AppointmentParticipant[]
  metrics      AppointmentMetric[]
  notes        Note[]
  assets       UploadedAsset[]
  measurements MeasurementEntry[]

  @@index([orgId, doctorId, scheduledAt])
  @@index([orgId, status, scheduledAt])
}

model AppointmentParticipant {
  appointmentId String
  patientId     String

  appointment Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  patient     Patient     @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@id([appointmentId, patientId])
  @@index([patientId])
}

model AppointmentMetric {
  id            String   @id @default(cuid())
  appointmentId String
  patientId     String
  metricTypeId  String
  value         String
  createdAt     DateTime @default(now())

  appointment Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  patient     Patient     @relation(fields: [patientId], references: [id], onDelete: Cascade)
  metricType  MetricType  @relation(fields: [metricTypeId], references: [id], onDelete: Restrict)

  @@index([appointmentId, patientId])
}

// ─── Notes ─────────────────────────────────────────────────────────────────────

model Note {
  id            String   @id @default(cuid())
  orgId         String
  patientId     String
  appointmentId String?
  authorId      String
  content       String
  isPublic      Boolean  @default(true)
  revision      Int      @default(1)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  patient     Patient      @relation(fields: [patientId], references: [id], onDelete: Cascade)
  appointment Appointment? @relation(fields: [appointmentId], references: [id], onDelete: SetNull)
  author      User         @relation(fields: [authorId], references: [id], onDelete: Restrict)

  @@index([orgId, patientId, createdAt])
}

// ─── Measurements ──────────────────────────────────────────────────────────────

model MeasurementEntry {
  id             String   @id @default(cuid())
  orgId          String
  patientId      String
  appointmentId  String?
  recorderUserId String
  metricTypeId   String
  source         String
  measuredAt     DateTime
  value          Decimal  @db.Decimal(10, 4)
  notes          String?
  createdAt      DateTime @default(now())

  patient      Patient     @relation(fields: [patientId], references: [id], onDelete: Cascade)
  appointment  Appointment? @relation(fields: [appointmentId], references: [id], onDelete: SetNull)
  recorderUser User        @relation(fields: [recorderUserId], references: [id], onDelete: Restrict)
  metricType   MetricType  @relation(fields: [metricTypeId], references: [id], onDelete: Restrict)

  @@index([orgId, patientId, measuredAt])
  @@index([appointmentId])
}

// ─── Assets ────────────────────────────────────────────────────────────────────

model UploadedAsset {
  id            String   @id @default(cuid())
  orgId         String
  patientId     String
  appointmentId String?
  uploadedById  String
  kind          String
  fileKey       String   @unique
  fileName      String
  fileUrl       String
  fileSize      Int
  createdAt     DateTime @default(now())

  patient     Patient      @relation(fields: [patientId], references: [id], onDelete: Cascade)
  appointment Appointment? @relation(fields: [appointmentId], references: [id], onDelete: SetNull)
  comments    AssetComment[]

  @@index([orgId, patientId, kind])
}

model AssetComment {
  id        String   @id @default(cuid())
  orgId     String
  assetId   String
  authorId  String
  content   String
  createdAt DateTime @default(now())

  asset  UploadedAsset @relation(fields: [assetId], references: [id], onDelete: Cascade)
  author User          @relation(fields: [authorId], references: [id], onDelete: Restrict)

  @@index([assetId, createdAt])
}

// ─── Doctor availability ───────────────────────────────────────────────────────

model WeeklySchedule {
  id        String @id @default(cuid())
  orgId     String
  userId    String
  dayOfWeek Int    // 0 = Sunday … 6 = Saturday
  startTime String // "HH:MM"
  endTime   String // "HH:MM"

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, dayOfWeek])
  @@index([orgId, userId])
}

model CalendarBlock {
  id        String   @id @default(cuid())
  orgId     String
  doctorId  String
  startsAt  DateTime
  endsAt    DateTime
  reason    String?
  createdAt DateTime @default(now())

  doctor User @relation(fields: [doctorId], references: [id], onDelete: Cascade)

  @@index([orgId, doctorId, startsAt])
}

// ─── Chat ──────────────────────────────────────────────────────────────────────

model Conversation {
  id        String        @id @default(cuid())
  orgId     String
  patientId String?
  userId    String?
  title     String?
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  patient  Patient?      @relation(fields: [patientId], references: [id], onDelete: Cascade)
  user     User?         @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages ChatMessage[]

  @@index([orgId, patientId])
  @@index([orgId, userId])
}

model ChatMessage {
  id             String       @id @default(cuid())
  conversationId String
  role           String
  content        String       @db.Text
  createdAt      DateTime     @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
}

// ─── Audit ─────────────────────────────────────────────────────────────────────

model AuditEvent {
  id         String   @id @default(cuid())
  orgId      String
  actorId    String
  action     String
  entityType String
  entityId   String
  beforeJson Json?
  afterJson  Json?
  createdAt  DateTime @default(now())

  actor User @relation(fields: [actorId], references: [id], onDelete: Restrict)

  @@index([orgId, entityType, entityId, createdAt])
}
